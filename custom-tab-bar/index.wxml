<view class="tab-bar">
  <view wx:for="{{list}}" wx:key="index" class="tab-item" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <image class="tab-icon {{selected === index ? 'active' : ''}}" src="{{item.iconPath}}" mode="aspectFit"></image>
    <text class="tab-text {{selected === index ? 'active' : ''}}">{{item.text}}</text>
  </view>
</view>
