/* pages/reservation/reservation.wxss */

.page {
  background: #f9f9f9;
  min-height: 100vh;
  padding: 164rpx 64rpx 200rpx;
}

/* Hero Section */
.hero {
  margin-bottom: 96rpx;
}

.hero-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.hero-title {
  font-size: 72rpx;
  font-weight: 300;
  color: #2d3435;
  line-height: 1.3;
  letter-spacing: -1rpx;
}

.hero-icon {
  font-size: 60rpx;
  opacity: 0.6;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(89, 96, 97, 0.7);
  letter-spacing: 2rpx;
  line-height: 1.6;
}

/* Form Section */
.form-section {
  margin-bottom: 160rpx;
}

.field {
  margin-bottom: 80rpx;
}

.field-label {
  display: block;
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 8rpx;
  color: #596061;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.field-input,
.field-textarea {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid rgba(117, 124, 125, 0.3);
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #2d3435;
  transition: border-color 0.3s;
}

.field-input:focus,
.field-textarea:focus {
  border-bottom-color: #5f5e5e;
}

.field-textarea {
  min-height: 120rpx;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: #5f5e5e;
  color: #faf7f6;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 8rpx;
  border: none;
  margin-top: 48rpx;
  transition: opacity 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* History Section */
.history-section {
  margin-top: 192rpx;
}

.history-title {
  display: block;
  font-size: 40rpx;
  color: #2d3435;
  margin-bottom: 64rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(117, 124, 125, 0.1);
}

.record-item {
  background: #f2f4f4;
  padding: 48rpx;
  border-radius: 16rpx;
  margin-bottom: 48rpx;
  transition: background 0.3s;
}

.record-item:active {
  background: #ffffff;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.record-name {
  font-size: 40rpx;
  color: #2d3435;
  flex: 1;
}

.record-status {
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  font-weight: 700;
}

.record-status.pending {
  background: #fdf2e2;
  color: #625b4f;
}

.record-status.done {
  background: #dde4e5;
  color: #596061;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-time {
  font-size: 24rpx;
  color: rgba(89, 96, 97, 0.6);
  letter-spacing: 2rpx;
}

.record-arrow {
  font-size: 28rpx;
  color: rgba(89, 96, 97, 0.6);
}

.empty-state {
  padding-top: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.2;
}

.empty-line {
  width: 2rpx;
  height: 96rpx;
  background: #2d3435;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  font-style: italic;
  color: #2d3435;
}

