/* pages/reservation/reservation.wxss */

.page {
  background: #f0f0f0;
  min-height: 100vh;
  padding: 24rpx 22rpx 60rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}

/* 表单 */
.field {
  margin-bottom: 28rpx;
}

.label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #FF6B35;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  background: #fafafa;
}

.input:focus {
  border-color: #FF6B35;
  background: #fff;
}

.textarea {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  background: #fafafa;
}

.hint {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
  display: block;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 12rpx;
}

.btn-submit[disabled] {
  opacity: 0.6;
}

/* 列表 */
.section-title {
  font-size: 28rpx;
  color: #888;
  padding: 8rpx 4rpx 16rpx;
  font-weight: bold;
}

.empty {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 60rpx 0;
}

.item-card {
  padding: 28rpx 28rpx 20rpx;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  flex: 1;
}

.status {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.status.pending {
  background: #FFF3E0;
  color: #FF6B35;
}

.status.done {
  background: #E8F5E9;
  color: #4CAF50;
}

.item-link {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.link-label {
  font-size: 24rpx;
  color: #888;
  flex-shrink: 0;
}

.link-text {
  font-size: 24rpx;
  color: #1976D2;
  word-break: break-all;
  text-decoration: underline;
}

.item-note {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.item-time {
  font-size: 22rpx;
  color: #bbb;
  text-align: right;
  margin-top: 8rpx;
}
