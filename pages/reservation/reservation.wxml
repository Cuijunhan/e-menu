<!--pages/reservation/reservation.wxml-->
<view class="page">
  <!-- Hero Section -->
  <view class="hero">
    <view class="hero-title-row">
      <text class="hero-title">想吃什么？\n告诉我</text>
      <text class="hero-icon">🍽️</text>
    </view>
    <text class="hero-subtitle">您的私人定制，每一道菜都是一次艺术的策展。</text>
  </view>

  <!-- Form Section -->
  <view class="form-section">
    <view class="field">
      <text class="field-label">菜名 *</text>
      <input
        class="field-input"
        placeholder="输入想吃的菜名，例如：红烧排骨"
        value="{{dishName}}"
        bindinput="onDishNameInput"
        maxlength="50"
      />
    </view>

    <view class="field">
      <text class="field-label">参考链接 (可选)</text>
      <input
        class="field-input"
        placeholder="粘贴抖音 / 小红书链接"
        value="{{link}}"
        bindinput="onLinkInput"
        maxlength="500"
      />
    </view>

    <view class="field">
      <text class="field-label">备注 (可选)</text>
      <textarea
        class="field-textarea"
        placeholder="有什么特别要求？比如：不要香菜、少辣..."
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="200"
        rows="2"
      />
    </view>

    <button class="submit-btn" bindtap="submit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交预约'}}
    </button>
  </view>

  <!-- History Section -->
  <view class="history-section">
    <text class="history-title">我的预约记录</text>

    <view wx:if="{{list.length === 0}}" class="empty-state">
      <view class="empty-line"></view>
      <text class="empty-text">Fin.</text>
    </view>

    <view wx:for="{{list}}" wx:key="id" class="record-item" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="record-header">
        <text class="record-name">{{item.dish_name}}</text>
        <view class="record-status {{item.status === '已处理' ? 'done' : 'pending'}}">
          {{item.status === '已处理' ? '已完成' : '待处理'}}
        </view>
      </view>
      <view class="record-footer">
        <text class="record-time">{{item.create_time}}</text>
        <text class="record-arrow">›</text>
      </view>
    </view>
  </view>
</view>
