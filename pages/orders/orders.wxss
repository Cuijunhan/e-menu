/* pages/orders/orders.wxss */

.page {
  background: #F5F5F5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 加载 / 空状态 */
.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: #999;
  font-size: 30rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  margin-top: 20rpx;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-id {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.order-status.pending {
  background: #FFF3E0;
  color: #FF6B35;
}

.order-status.done {
  background: #E8F5E9;
  color: #4CAF50;
}

/* 菜品列表 */
.order-items {
  padding: 16rpx 30rpx;
}

.order-item-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.order-item-row:last-child {
  border-bottom: none;
}

.dish-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.dish-qty {
  font-size: 26rpx;
  color: #999;
  margin: 0 20rpx;
}

.dish-price {
  font-size: 28rpx;
  color: #FF6B35;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #FAFAFA;
  border-top: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 24rpx;
  color: #bbb;
}

.order-total {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
