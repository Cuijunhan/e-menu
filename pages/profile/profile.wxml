<!--pages/profile/profile.wxml-->
<view class="page">
  <!-- 授权引导页 -->
  <view wx:if="{{!hasAuth}}" class="auth-guide">
    <view class="auth-content">
      <text class="auth-title">欢迎使用</text>
      <text class="auth-desc">请完善您的个人信息</text>
      <button class="auth-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        选择头像
      </button>
    </view>
  </view>

  <!-- 用户信息区 -->
  <view wx:else class="user-section">
    <button wx:if="{{!avatarUrl}}" class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <view class="avatar">
        <text class="avatar-emoji">👤</text>
      </view>
    </button>
    <view wx:else class="avatar">
      <image class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
    </view>
    <view class="user-info">
      <input wx:if="{{!nickName || nickName === '家庭用户'}}" class="user-name-input" type="nickname" placeholder="点击输入昵称" bindblur="onNicknameBlur" />
      <text wx:else class="user-name">{{nickName}}</text>
      <text class="user-label">MEMBER SINCE MMXXIII</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-label">余额</text>
      <text class="stat-value">¥{{balance}}</text>
    </view>
    <view class="stat-card" bindtap="onCouponTap">
      <text class="stat-label">兑换券</text>
      <text class="stat-value">03</text>
    </view>
  </view>

  <!-- 提示信息 -->
  <view wx:if="{{showToast}}" class="toast-msg">{{toastMsg}}</view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <text class="section-label">ESSENTIALS</text>
    <view class="menu-group">
      <view class="menu-item" bindtap="goToOrders">
        <text class="menu-icon">📋</text>
        <text class="menu-text">历史订单</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToCart">
        <text class="menu-icon">🛒</text>
        <text class="menu-text">购物车</text>
        <view wx:if="{{cartCount > 0}}" class="badge">{{cartCount}}</view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onRecharge">
        <text class="menu-icon">💰</text>
        <text class="menu-text">充值</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

</view>
