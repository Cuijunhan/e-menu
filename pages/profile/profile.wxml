<!--pages/profile/profile.wxml-->
<view class="page">

  <!-- 用户信息卡 -->
  <view class="user-card">
    <view class="avatar">
      <text class="avatar-text">👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">家庭用户</text>
      <text class="user-sub">欢迎使用家庭点餐</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCart">
      <text class="menu-icon">🛒</text>
      <text class="menu-text">购物车</text>
      <view wx:if="{{cartCount > 0}}" class="badge">{{cartCount}}</view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

</view>
