<!--pages/profile/profile.wxml-->
<view class="page">

  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="avatar" bindtap="goToEditProfile">
      <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
      <text wx:else class="avatar-text">{{nickname ? nickname[0] : '?'}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{nickname}}</text>
      <view class="family-row">
        <text class="family-label">{{familyName}}</text>
        <view class="role-badge {{role}}">
          <text>{{role === 'admin' ? 'ADMIN' : 'MEMBER'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 邀请码（管理员可见） -->
  <view wx:if="{{isAdmin}}" class="invite-section" bindtap="copyInviteCode">
    <view class="invite-inner">
      <view>
        <text class="invite-hint">邀请码（点击复制）</text>
        <text class="invite-code">{{inviteCode}}</text>
      </view>
      <text class="invite-icon">⎘</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <text class="section-label">ESSENTIALS</text>
    <view class="menu-group">
      <view class="menu-item" bindtap="goToEditProfile">
        <text class="menu-icon">👤</text>
        <text class="menu-text">编辑资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToOrders">
        <text class="menu-icon">📋</text>
        <text class="menu-text">历史订单</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToCart">
        <text class="menu-icon">🛒</text>
        <text class="menu-text">购物车</text>
        <view wx:if="{{cartCount > 0}}" class="badge">{{cartCount}}</view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{isAdmin}}" class="menu-section" style="margin-top:32rpx;">
    <text class="section-label">ADMIN</text>
    <view class="menu-group">
      <view class="menu-item" bindtap="goToAdmin">
        <text class="menu-icon">⚙</text>
        <text class="menu-text">管理后台</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="menu-section" style="margin-top:32rpx;">
    <text class="section-label">ACCOUNT</text>
    <view class="menu-group">
      <view class="menu-item danger" bindtap="leaveFamily">
        <text class="menu-icon">🚪</text>
        <text class="menu-text danger-text">退出家庭</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view style="height: 160rpx;"></view>
</view>
