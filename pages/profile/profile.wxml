<!--pages/profile/profile.wxml-->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="header-title">THE CURATED</text>
    <view class="header-right"></view>
  </view>

  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="avatar">
      <text class="avatar-emoji">👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">家庭用户</text>
      <text class="user-label">MEMBER SINCE MMXXIII</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-label">MY POINTS</text>
      <text class="stat-value">1,240</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">COUPONS</text>
      <text class="stat-value">03</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <text class="section-label">ESSENTIALS</text>
    <view class="menu-group">
      <view class="menu-item" bindtap="goToOrders">
        <text class="menu-icon">📋</text>
        <text class="menu-text">My Orders</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToCart">
        <text class="menu-icon">🛒</text>
        <text class="menu-text">Shopping Cart</text>
        <view wx:if="{{cartCount > 0}}" class="badge">{{cartCount}}</view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

</view>
