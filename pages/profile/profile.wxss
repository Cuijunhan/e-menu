/* pages/profile/profile.wxss */

.page {
  background: #f9f9f9;
  min-height: 100vh;
  padding-top: 80rpx;
  padding-bottom: 160rpx;
}

/* 用户信息区 */
.user-section {
  padding: 72rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #2d3435;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
}

.avatar-text {
  font-size: 72rpx;
  color: #ffffff;
  font-weight: 300;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-name {
  font-size: 72rpx;
  font-weight: 300;
  letter-spacing: -2rpx;
  color: #2d3435;
  line-height: 1.2;
}

.family-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.family-label {
  font-size: 24rpx;
  color: #acb3b4;
  letter-spacing: 2rpx;
}

.role-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.role-badge.admin {
  background: #2d3435;
  color: #ffffff;
}

.role-badge.member {
  background: #eef0f0;
  color: #acb3b4;
}

/* 邀请码 */
.invite-section {
  margin: 0 48rpx 48rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(45,52,53,0.04);
}

.invite-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.invite-hint {
  display: block;
  font-size: 20rpx;
  color: #acb3b4;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.invite-code {
  display: block;
  font-size: 56rpx;
  font-weight: 300;
  letter-spacing: 10rpx;
  color: #2d3435;
}

.invite-icon {
  font-size: 48rpx;
  color: #acb3b4;
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  padding: 0 48rpx 96rpx;
}

.stat-card {
  background: #ffffff;
  padding: 48rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 256rpx;
  transition: all 0.3s;
}

.stat-card:active {
  background: #f9f9f9;
}

.stat-label {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(89, 96, 97, 0.5);
}

.stat-value {
  font-size: 48rpx;
  font-style: italic;
  color: #2d3435;
}

/* 菜单列表 */
.menu-section {
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-label {
  font-size: 20rpx;
  letter-spacing: 12rpx;
  color: rgba(89, 96, 97, 0.4);
  margin-left: 8rpx;
}

.menu-group {
  background: rgba(242, 244, 244, 0.5);
  border-radius: 32rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 40rpx;
  transition: all 0.3s;
}

.menu-item:active {
  background: #f2f4f4;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 32rpx;
  opacity: 0.8;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  letter-spacing: 2rpx;
  color: #2d3435;
}

.badge {
  background: #5f5e5e;
  color: #faf7f6;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  margin-right: 16rpx;
  font-weight: 700;
}

.menu-arrow {
  font-size: 40rpx;
  color: rgba(172, 179, 180, 0.4);
}

/* 危险操作 */
.danger-text {
  color: #e74c3c;
}
