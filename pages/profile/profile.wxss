/* pages/profile/profile.wxss */

.page {
  background: #f9f9f9;
  min-height: 100vh;
  padding-top: 128rpx;
  padding-bottom: 160rpx;
}

/* 顶部导航栏 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 128rpx;
  background: rgba(249, 249, 249, 0.85);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  z-index: 100;
}

.header-left,
.header-right {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 6rpx;
  color: #2d3435;
  text-align: center;
}

/* 用户信息区 */
.user-section {
  padding: 96rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.avatar {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  background: #f2f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  border: 2rpx solid rgba(172, 179, 180, 0.1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.avatar-emoji {
  font-size: 96rpx;
  opacity: 0.8;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 80rpx;
  font-weight: 300;
  letter-spacing: -2rpx;
  color: #2d3435;
  line-height: 1.2;
}

.user-label {
  font-size: 20rpx;
  letter-spacing: 8rpx;
  color: rgba(89, 96, 97, 0.6);
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  padding: 0 48rpx 96rpx;
}

.stat-card {
  background: #ffffff;
  padding: 48rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 256rpx;
  transition: all 0.3s;
}

.stat-card:active {
  background: #f9f9f9;
}

.stat-label {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(89, 96, 97, 0.5);
}

.stat-value {
  font-size: 48rpx;
  font-style: italic;
  color: #2d3435;
}

/* 菜单列表 */
.menu-section {
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-label {
  font-size: 20rpx;
  letter-spacing: 12rpx;
  color: rgba(89, 96, 97, 0.4);
  margin-left: 8rpx;
}

.menu-group {
  background: rgba(242, 244, 244, 0.5);
  border-radius: 32rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 40rpx;
  transition: all 0.3s;
}

.menu-item:active {
  background: #f2f4f4;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 32rpx;
  opacity: 0.8;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  letter-spacing: 2rpx;
  color: #2d3435;
}

.badge {
  background: #5f5e5e;
  color: #faf7f6;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  margin-right: 16rpx;
  font-weight: 700;
}

.menu-arrow {
  font-size: 40rpx;
  color: rgba(172, 179, 180, 0.4);
}
