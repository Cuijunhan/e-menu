<!--pages/cart/cart.wxml-->
<view class="page">

  <!-- 购物车为空 -->
  <view wx:if="{{cart.length === 0}}" class="empty">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <view class="back-btn" bindtap="onBack">去点菜</view>
  </view>

  <!-- 购物车列表 -->
  <view wx:else>
    <view class="cart-list">
      <view wx:for="{{cart}}" wx:key="dish.id" class="cart-item">
        <view class="item-img-placeholder">
          <text>🍽</text>
        </view>
        <view class="item-info">
          <text class="item-name">{{item.dish.name}}</text>
          <text class="item-price">¥{{item.dish.price}}</text>
        </view>
        <view class="item-ctrl">
          <view class="qty-btn minus" bindtap="onRemove" data-dish="{{item.dish}}">-</view>
          <text class="qty-num">{{item.quantity}}</text>
          <view class="qty-btn add" bindtap="onAdd" data-dish="{{item.dish}}">+</view>
        </view>
      </view>
    </view>

    <!-- 底部结算栏 -->
    <view class="checkout-bar">
      <view class="total-wrap">
        <text class="total-label">合计：</text>
        <text class="total-price">¥{{cartTotal}}</text>
      </view>
      <view class="submit-btn" bindtap="onSubmit">提交订单</view>
    </view>
  </view>

</view>
