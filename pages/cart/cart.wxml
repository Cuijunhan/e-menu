<!--pages/cart/cart.wxml-->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="header-title">THE CURATED</text>
    <view class="header-right"></view>
  </view>

  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">Cart</text>
    <text class="page-subtitle">SELECTED ESSENTIALS</text>
  </view>

  <!-- 购物车为空 -->
  <view wx:if="{{cart.length === 0}}" class="empty">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">Your sanctuary is quiet.</text>
    <view class="back-btn" bindtap="onBack">Discover Objects</view>
  </view>

  <!-- 购物车列表 -->
  <view wx:else class="content">
    <view class="cart-list">
      <view wx:for="{{cart}}" wx:key="dish.id" class="cart-item">
        <view class="item-img">
          <text class="item-emoji">🍽</text>
        </view>
        <view class="item-details">
          <view class="item-top">
            <text class="item-name">{{item.dish.name}}</text>
            <text class="item-remove" bindtap="onRemove" data-dish="{{item.dish}}">×</text>
          </view>
          <text class="item-desc">{{item.dish.description || 'Handcrafted'}}</text>
          <view class="item-bottom">
            <view class="qty-ctrl">
              <text class="qty-btn minus" bindtap="onRemove" data-dish="{{item.dish}}">−</text>
              <text class="qty-num">{{item.quantity}}</text>
              <text class="qty-btn add" bindtap="onAdd" data-dish="{{item.dish}}">+</text>
            </view>
            <text class="item-price">¥{{item.dish.price * item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部结算区域 -->
    <view class="checkout-section">
      <view class="summary-row">
        <text class="summary-label">SUBTOTAL</text>
        <text class="summary-value">¥{{cartTotal}}</text>
      </view>
      <view class="checkout-btn" bindtap="onSubmit">
        <text>Proceed to Checkout</text>
        <text class="arrow">→</text>
      </view>
    </view>
  </view>

</view>
