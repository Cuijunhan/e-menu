/* pages/cart/cart.wxss */

.page {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  color: #999;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.back-btn {
  margin-top: 40rpx;
  background: #FF6B35;
  color: #fff;
  padding: 22rpx 80rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
}

/* 列表 */
.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.item-img-placeholder {
  width: 100rpx;
  height: 100rpx;
  background: #FFF0E8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  padding: 0 24rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.item-price {
  font-size: 28rpx;
  color: #FF6B35;
  margin-top: 8rpx;
  display: block;
}

.item-ctrl {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

.qty-btn.add {
  background: #FF6B35;
  color: #fff;
}

.qty-btn.minus {
  background: #fff;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

.qty-num {
  font-size: 30rpx;
  font-weight: bold;
  min-width: 52rpx;
  text-align: center;
  color: #333;
}

/* 结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.08);
  z-index: 100;
}

.total-wrap {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B35;
}

.submit-btn {
  background: #FF6B35;
  color: #fff;
  font-size: 30rpx;
  padding: 22rpx 60rpx;
  border-radius: 50rpx;
  font-weight: bold;
}
