/* pages/cart/cart.wxss */

.page {
  background: #f9f9f9;
  min-height: 100vh;
  padding-top: 128rpx;
}

/* 顶部导航栏 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 128rpx;
  background: rgba(249, 249, 249, 0.85);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  z-index: 100;
}

.header-left,
.header-right {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 6rpx;
  color: #2d3435;
  text-align: center;
}

/* 页面标题 */
.page-header {
  padding: 128rpx 48rpx 64rpx;
}

.page-title {
  font-size: 112rpx;
  line-height: 1.1;
  letter-spacing: -2rpx;
  color: #2d3435;
  opacity: 0.9;
  display: block;
}

.page-subtitle {
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: #757c7d;
  margin-top: 32rpx;
  display: block;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 320rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.empty-text {
  color: #757c7d;
  font-size: 40rpx;
  font-style: italic;
  margin-top: 48rpx;
}

.back-btn {
  margin-top: 64rpx;
  color: #596061;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  border-bottom: 1rpx solid #acb3b4;
  padding-bottom: 8rpx;
}

/* 内容区域 */
.content {
  padding: 0 48rpx 320rpx;
}

.cart-list {
  display: flex;
  flex-direction: column;
  gap: 96rpx;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  gap: 48rpx;
}

.item-img {
  width: 192rpx;
  height: 256rpx;
  background: #f2f4f4;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-emoji {
  font-size: 80rpx;
  opacity: 0.8;
  filter: grayscale(100%);
}

.item-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 256rpx;
  justify-content: space-between;
  padding: 8rpx 0;
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-name {
  font-size: 36rpx;
  color: #2d3435;
  line-height: 1.3;
  flex: 1;
}

.item-remove {
  font-size: 32rpx;
  color: #acb3b4;
  padding: 0 16rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #757c7d;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.qty-ctrl {
  display: flex;
  align-items: center;
  gap: 48rpx;
  background: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 48rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.qty-btn {
  font-size: 32rpx;
  color: #757c7d;
  transition: all 0.3s;
}

.qty-btn.add {
  color: #5f5e5e;
}

.qty-btn.minus {
  color: #757c7d;
}

.qty-num {
  font-size: 28rpx;
  font-weight: 500;
  min-width: 32rpx;
  text-align: center;
  color: #2d3435;
}

.item-price {
  font-size: 36rpx;
  color: #2d3435;
}

/* 结算区域 */
.checkout-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(40rpx);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  z-index: 100;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: #757c7d;
}

.summary-value {
  font-size: 40rpx;
  color: #2d3435;
}

.checkout-btn {
  width: 100%;
  background: #5f5e5e;
  color: #faf7f6;
  padding: 40rpx;
  border-radius: 64rpx;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(45, 52, 53, 0.05);
  transition: all 0.3s;
}

.arrow {
  font-size: 28rpx;
}
