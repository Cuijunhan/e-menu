/* pages/index/index.wxss */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f9f9f9;
}

/* 顶部导航栏 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(249, 249, 249, 0.92);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  /* padding-top 由 JS 动态注入状态栏高度 */
  padding-bottom: 0;
}

.header-title {
  font-size: 28rpx;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 6rpx;
  color: #acb3b4;
  text-align: center;
  display: block;
  padding: 16rpx 0 20rpx;
}

/* 三个固定类型 Tab */
.type-tabs {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid #eef0f0;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #acb3b4;
  letter-spacing: 2rpx;
  position: relative;
  transition: color 0.2s;
}

.type-tab.active {
  color: #2d3435;
  font-weight: 600;
}

.type-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 4rpx;
  background: #2d3435;
  border-radius: 4rpx;
}

/* 主区域 */
.main {
  display: flex;
  flex-direction: row;
  height: 100vh;
  /* padding-top 由 JS 动态注入（状态栏+标题+tab总高度）*/
  overflow: hidden;
}

/* 左侧分类栏 */
.cat-sidebar {
  width: 160rpx;
  height: 100%;
  background: #ebeeef;
  flex-shrink: 0;
  padding-top: 24rpx;
}

.cat-item {
  padding: 40rpx 16rpx;
  font-size: 22rpx;
  color: #acb3b4;
  text-align: center;
  border-left: 4rpx solid transparent;
  line-height: 1.4;
  letter-spacing: 2rpx;
  transition: all 0.2s;
}

.cat-item.active {
  color: #2d3435;
  font-weight: 700;
  border-left-color: #2d3435;
  background: rgba(45,52,53,0.04);
}

/* 右侧菜品列表 */
.dish-scroll {
  flex: 1;
  height: 100%;
  background: #f9f9f9;
  padding: 32rpx 24rpx 400rpx 32rpx;
}

.dish-card {
  display: flex;
  flex-direction: row;
  background: #ffffff;
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(45, 52, 53, 0.05);
  height: 220rpx;
}

.dish-img-wrap {
  width: 200rpx;
  height: 220rpx;
  flex-shrink: 0;
}

.dish-img {
  width: 100%;
  height: 100%;
}

.dish-img-placeholder {
  width: 100%;
  height: 100%;
  background: #f2f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-emoji {
  font-size: 72rpx;
  opacity: 0.3;
}

.dish-info {
  flex: 1;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #2d3435;
  line-height: 1.3;
}

.dish-desc {
  font-size: 22rpx;
  color: #acb3b4;
  margin-top: 8rpx;
  line-height: 1.5;
  font-style: italic;
}

.dish-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.dish-price {
  font-size: 32rpx;
  font-weight: 500;
  color: #2d3435;
}

/* 数量控制 */
.qty-ctrl {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.qty-btn.add {
  background: #2d3435;
  color: #ffffff;
}

.qty-btn.minus {
  background: #ffffff;
  color: #2d3435;
  border: 2rpx solid #dde4e5;
}

.qty-num {
  font-size: 28rpx;
  font-weight: 500;
  min-width: 36rpx;
  text-align: center;
  color: #2d3435;
}

.empty-tip {
  text-align: center;
  color: #acb3b4;
  padding: 160rpx 0;
  font-size: 28rpx;
  font-style: italic;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 85%;
  max-width: 900rpx;
  height: 120rpx;
  background: rgba(45, 52, 53, 0.92);
  backdrop-filter: blur(40rpx);
  border-radius: 64rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  z-index: 200;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.3s, opacity 0.3s;
}

.cart-bar.hidden {
  transform: translateX(-50%) translateY(120rpx);
  opacity: 0;
  pointer-events: none;
}

.cart-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.cart-icon-wrap {
  position: relative;
}

.cart-icon {
  font-size: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  background: #ffffff;
  color: #2d3435;
  font-size: 18rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  padding: 0 6rpx;
}

.cart-label {
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
}

.cart-right {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.cart-total {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
}

.cart-btn {
  background: rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.5);
  font-size: 22rpx;
  padding: 14rpx 40rpx;
  border-radius: 48rpx;
  letter-spacing: 2rpx;
}

.cart-btn.enabled {
  background: #ffffff;
  color: #2d3435;
}

/* 菜品详情弹窗 */
.dish-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.dish-modal-content {
  width: 88%;
  max-height: 76vh;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-close-btn {
  width: 96rpx;
  height: 96rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #2d3435;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  flex-shrink: 0;
}

.modal-scroll {
  max-height: 82vh;
}

.modal-img-wrap {
  width: 100%;
  height: 320rpx;
}

.modal-img {
  width: 100%;
  height: 320rpx;
  display: block;
}

.modal-img-placeholder {
  width: 100%;
  height: 320rpx;
  background: #f2f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-img-emoji {
  font-size: 120rpx;
  opacity: 0.25;
}

.modal-info {
  padding: 36rpx 48rpx 28rpx;
  border-bottom: 1rpx solid #f2f4f4;
}

.modal-name-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #2d3435;
  flex: 1;
  margin-right: 24rpx;
}

.modal-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3435;
  flex-shrink: 0;
}

.modal-desc {
  display: block;
  font-size: 26rpx;
  color: #757c7d;
  font-style: italic;
  line-height: 1.6;
}

.modal-sections {
  padding: 32rpx 48rpx;
}

.modal-section {
  margin-bottom: 36rpx;
}

.section-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #acb3b4;
  margin-bottom: 12rpx;
}

.section-value {
  display: block;
  font-size: 28rpx;
  color: #2d3435;
  line-height: 1.8;
  white-space: pre-wrap;
}
