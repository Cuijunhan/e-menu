/* pages/index/index.wxss */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f9f9f9;
}

/* 顶部导航栏 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 128rpx;
  background: rgba(249, 249, 249, 0.85);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  z-index: 100;
}

.header-left,
.header-right {
  flex: 1;
}

.header-right {
  display: flex;
  justify-content: flex-end;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 6rpx;
  color: #2d3435;
  text-align: center;
}

.cart-icon-small {
  font-size: 40rpx;
}

/* 主区域 */
.main {
  display: flex;
  flex-direction: row;
  height: 100vh;
  padding-top: 128rpx;
  overflow: hidden;
}

/* 左侧分类栏 */
.cat-sidebar {
  width: 192rpx;
  height: 100%;
  background: #ebeeef;
  flex-shrink: 0;
  padding-top: 96rpx;
}

.cat-item {
  padding: 40rpx 16rpx;
  font-size: 20rpx;
  color: #acb3b4;
  text-align: center;
  border-left: 4rpx solid transparent;
  background: transparent;
  line-height: 1.4;
  letter-spacing: 2rpx;
  transition: all 0.3s;
}

.cat-item.active {
  background: transparent;
  color: #2d3435;
  font-weight: 700;
  border-left-color: #5f5e5e;
}

/* 右侧菜品列表 */
.dish-scroll {
  flex: 1;
  height: 100%;
  background: #f9f9f9;
  padding: 64rpx 64rpx 200rpx;
}

.dish-card {
  display: flex;
  flex-direction: row;
  background: #ffffff;
  margin-bottom: 48rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 40rpx rgba(45, 52, 53, 0.04);
  transition: all 0.3s;
}

.dish-img-placeholder {
  width: 200rpx;
  height: 240rpx;
  background: #f2f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dish-emoji {
  font-size: 80rpx;
  opacity: 0.4;
}

.dish-info {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name {
  font-size: 36rpx;
  font-weight: 400;
  color: #2d3435;
  line-height: 1.3;
}

.dish-desc {
  font-size: 24rpx;
  color: #757c7d;
  margin-top: 12rpx;
  line-height: 1.5;
  font-style: italic;
}

.dish-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.dish-price {
  font-size: 32rpx;
  font-weight: 500;
  color: #5f5e5e;
}

/* 数量控制 */
.qty-ctrl {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 400;
  transition: all 0.3s;
}

.qty-btn.add {
  background: #5f5e5e;
  color: #faf7f6;
}

.qty-btn.minus {
  background: #ffffff;
  color: #5f5e5e;
  border: 2rpx solid #dde4e5;
}

.qty-num {
  font-size: 28rpx;
  font-weight: 500;
  min-width: 40rpx;
  text-align: center;
  color: #2d3435;
}

.empty-tip {
  text-align: center;
  color: #acb3b4;
  padding: 200rpx 0;
  font-size: 28rpx;
  font-weight: 300;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 64rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 900rpx;
  height: 128rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(40rpx);
  border-radius: 64rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  z-index: 100;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(172, 179, 180, 0.1);
}

.cart-left {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.cart-icon-wrap {
  position: relative;
}

.cart-icon {
  font-size: 56rpx;
}

.cart-badge {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  background: #5f5e5e;
  color: #faf7f6;
  font-size: 20rpx;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  padding: 0 8rpx;
}

.cart-label {
  color: #757c7d;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.cart-right {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.cart-total {
  color: #2d3435;
  font-size: 36rpx;
  font-weight: 700;
}

.cart-btn {
  background: #e3e2e2;
  color: #acb3b4;
  font-size: 24rpx;
  padding: 16rpx 48rpx;
  border-radius: 48rpx;
  letter-spacing: 4rpx;
  transition: all 0.3s;
}

.cart-btn.enabled {
  background: #5f5e5e;
  color: #faf7f6;
}
