<!--pages/index/index.wxml-->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <text class="header-title">THE CURATED</text>
    <!-- 三个固定类型 Tab -->
    <view class="type-tabs">
      <view
        wx:for="{{types}}"
        wx:key="key"
        class="type-tab {{activeType === item.key ? 'active' : ''}}"
        bindtap="onTypeTap"
        data-key="{{item.key}}"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 主内容区：左侧分类 + 右侧菜品 -->
  <view class="main" style="padding-top: {{headerHeight}}px;">

    <!-- 左侧分类栏 -->
    <scroll-view class="cat-sidebar" scroll-y>
      <view
        class="cat-item {{activeCategoryId === null ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id=""
      >全部</view>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="cat-item {{activeCategoryId === item.id ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view class="dish-scroll" scroll-y bindscroll="onScroll">
      <view
        wx:for="{{dishes}}"
        wx:key="id"
        class="dish-card"
        bindtap="onDishTap"
        data-dish="{{item}}"
      >
        <view class="dish-img-wrap">
          <image wx:if="{{item.image}}" class="dish-img" src="{{item.image}}" mode="aspectFill"/>
          <view wx:else class="dish-img-placeholder"><text class="dish-emoji">🍽</text></view>
        </view>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.description}}</text>
          <view class="dish-bottom">
            <text class="dish-price">¥{{item.price}}</text>
            <view class="qty-ctrl">
              <view
                wx:if="{{dishQuantities[item.id] > 0}}"
                class="qty-btn minus"
                catchtap="onRemoveTap"
                data-dish="{{item}}"
              >-</view>
              <text
                wx:if="{{dishQuantities[item.id] > 0}}"
                class="qty-num"
              >{{dishQuantities[item.id]}}</text>
              <view class="qty-btn add" catchtap="onAddTap" data-dish="{{item}}">+</view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{dishes.length === 0}}" class="empty-tip">
        <text>暂无菜品</text>
      </view>
      <view style="height: 350rpx;"></view>
    </scroll-view>

  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar {{cartBarHidden ? 'hidden' : ''}}" bindtap="goToCart">
    <view class="cart-left">
      <view class="cart-icon-wrap">
        <text class="cart-icon">🛒</text>
        <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
      </view>
      <text class="cart-label">{{cartCount > 0 ? '购物车' : '未选商品'}}</text>
    </view>
    <view class="cart-right">
      <text wx:if="{{cartCount > 0}}" class="cart-total">¥{{cartTotal}}</text>
      <view class="cart-btn {{cartCount > 0 ? 'enabled' : ''}}">
        <text>去结算</text>
      </view>
    </view>
  </view>

  <!-- 菜品详情弹窗 -->
  <view wx:if="{{showDishDetail}}" class="dish-modal" catchtap="closeDishDetail">
    <view class="dish-modal-content" catchtap="stopPropagation">
      <scroll-view class="modal-scroll" scroll-y>
        <!-- 菜品图片 -->
        <view class="modal-img-wrap">
          <image wx:if="{{selectedDish.image}}" class="modal-img" src="{{selectedDish.image}}" mode="aspectFill"/>
          <view wx:else class="modal-img-placeholder">
            <text class="modal-img-emoji">🍽</text>
          </view>
        </view>

        <!-- 名称 + 价格 -->
        <view class="modal-info">
          <view class="modal-name-row">
            <text class="modal-title">{{selectedDish.name}}</text>
            <text class="modal-price">¥{{selectedDish.price}}</text>
          </view>
          <text wx:if="{{selectedDish.description}}" class="modal-desc">{{selectedDish.description}}</text>
        </view>

        <!-- 详细信息 -->
        <view class="modal-sections">
          <view class="modal-section" wx:if="{{selectedDish.ingredients}}">
            <text class="section-label">原材料准备</text>
            <text class="section-value">{{selectedDish.ingredients}}</text>
          </view>
          <view class="modal-section" wx:if="{{selectedDish.instructions}}">
            <text class="section-label">做法步骤</text>
            <text class="section-value">{{selectedDish.instructions}}</text>
          </view>
          <view class="modal-section" wx:if="{{selectedDish.notes}}">
            <text class="section-label">注意事项</text>
            <text class="section-value">{{selectedDish.notes}}</text>
          </view>
        </view>

        <view style="height: 48rpx;"></view>
      </scroll-view>
    </view>

    <!-- 关闭按钮：弹窗正下方居中 -->
    <view class="modal-close-btn" catchtap="closeDishDetail">×</view>
  </view>

</view>
