<!--pages/index/index.wxml-->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="header-title">THE CURATED</text>
    <view class="header-right">
      <text class="cart-icon-small">🛒</text>
    </view>
  </view>

  <!-- 主内容区：左侧分类 + 右侧菜品 -->
  <view class="main">

    <!-- 左侧分类栏 -->
    <scroll-view class="cat-sidebar" scroll-y>
      <!-- 主分类 -->
      <view
        wx:for="{{mainCategories}}"
        wx:key="id"
        class="main-cat-item {{activeMainCategoryId === item.id ? 'active' : ''}}"
        bindtap="onMainCategoryTap"
        data-id="{{item.id}}"
      >{{item.name}}</view>

      <view class="cat-divider"></view>

      <!-- 子分类 -->
      <view
        class="cat-item {{activeCategoryId === null ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{0}}"
      >全部</view>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="cat-item {{activeCategoryId === item.id ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
      >{{item.name}}</view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view class="dish-scroll" scroll-y bindscroll="onScroll">
      <view
        wx:for="{{dishes}}"
        wx:key="id"
        class="dish-card"
        bindtap="onDishTap"
        data-dish="{{item}}"
      >
        <view class="dish-img-placeholder">
          <text class="dish-emoji">🍽</text>
        </view>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.description}}</text>
          <view class="dish-bottom">
            <text class="dish-price">¥{{item.price}}</text>
            <view class="qty-ctrl">
              <view
                wx:if="{{dishQuantities[item.id] > 0}}"
                class="qty-btn minus"
                catchtap="onRemoveTap"
                data-dish="{{item}}"
              >-</view>
              <text
                wx:if="{{dishQuantities[item.id] > 0}}"
                class="qty-num"
              >{{dishQuantities[item.id]}}</text>
              <view
                class="qty-btn add"
                catchtap="onAddTap"
                data-dish="{{item}}"
              >+</view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{dishes.length === 0}}" class="empty-tip">
        <text>暂无菜品</text>
      </view>
      <view style="height: 350rpx;"></view>
    </scroll-view>

  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar {{cartBarHidden ? 'hidden' : ''}}" bindtap="goToCart">
    <view class="cart-left">
      <view class="cart-icon-wrap">
        <text class="cart-icon">🛒</text>
        <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
      </view>
      <text class="cart-label">{{cartCount > 0 ? '购物车' : '未选商品'}}</text>
    </view>
    <view class="cart-right">
      <text wx:if="{{cartCount > 0}}" class="cart-total">¥{{cartTotal}}</text>
      <view class="cart-btn {{cartCount > 0 ? 'enabled' : ''}}">
        <text>去结算</text>
      </view>
    </view>
  </view>

  <!-- 菜品详情弹窗 -->
  <view wx:if="{{showDishDetail}}" class="dish-modal" catchtap="closeDishDetail">
    <view class="dish-modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{selectedDish.name}}</text>
        <text class="modal-close" catchtap="closeDishDetail">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="modal-section">
          <text class="section-label">价格</text>
          <text class="section-value">¥{{selectedDish.price}}</text>
        </view>
        <view class="modal-section" wx:if="{{selectedDish.description}}">
          <text class="section-label">简介</text>
          <text class="section-value">{{selectedDish.description}}</text>
        </view>
        <view class="modal-section" wx:if="{{selectedDish.ingredients}}">
          <text class="section-label">食材</text>
          <text class="section-value">{{selectedDish.ingredients}}</text>
        </view>
        <view class="modal-section" wx:if="{{selectedDish.instructions}}">
          <text class="section-label">做法</text>
          <text class="section-value">{{selectedDish.instructions}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

</view>
