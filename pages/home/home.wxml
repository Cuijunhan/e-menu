<!--pages/home/home.wxml-->
<view class="page">
  <!-- 顶部导航栏 -->
  <!-- <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-content">
      <view class="header-left"></view>
      <text class="header-title">康康吃什么</text>
      <view class="header-right"></view>
    </view>
  </view> -->

  <view class="main">
    <!-- Hero 轮播图区域 -->
    <swiper class="hero-section" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{5000}}" duration="{{500}}" circular="{{true}}">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="hero-img" src="{{item.image}}" mode="aspectFill"/>
        <view class="hero-overlay"></view>
        <view class="hero-text" wx:if="{{item.title}}">
          <text class="hero-title">{{item.title}}</text>
        </view>
      </swiper-item>
    </swiper>

    <!-- 功能网格 -->
    <view class="grid-menu">
      <view class="grid-item" bindtap="goToFood">
        <view class="icon-box">
          <image class="icon-img" src="/images/icon-cooking.png" mode="aspectFit"/>
        </view>
        <text class="item-label">COOKING</text>
        <text class="item-desc">Slow nourishment</text>
      </view>

      <view class="grid-item offset" bindtap="goToCoffee">
        <view class="icon-box">
          <image class="icon-img" src="/images/icon-coffee.png" mode="aspectFit"/>
        </view>
        <text class="item-label">COFFEE</text>
        <text class="item-desc">Morning ritual</text>
      </view>

      <view class="grid-item" bindtap="goToCocktail">
        <view class="icon-box">
          <image class="icon-img" src="/images/icon-cocktail.png" mode="aspectFit"/>
        </view>
        <text class="item-label">WINE</text>
        <text class="item-desc">Earthly notes</text>
      </view>

      <view class="grid-item offset" bindtap="goToRandom">
        <view class="icon-box">
          <image class="icon-img" src="/images/icon-random.png" mode="aspectFit"/>
        </view>
        <text class="item-label">RANDOM</text>
        <text class="item-desc">Chance encounters</text>
      </view>

      <view class="grid-item" bindtap="goToHistory">
        <view class="icon-box">
          <image class="icon-img" src="/images/icon-history.png" mode="aspectFit"/>
        </view>
        <text class="item-label">HISTORY</text>
        <text class="item-desc">Past dialogues</text>
      </view>

      <view class="grid-item offset" bindtap="goToReservation">
        <view class="icon-box">
          <image class="icon-img" src="/images/icon-wish.png" mode="aspectFit"/>
        </view>
        <text class="item-label">WISH</text>
        <text class="item-desc">Private space</text>
      </view>
    </view>
  </view>

</view>
