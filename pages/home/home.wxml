<!--pages/home/home.wxml-->
<view class="page">

  <!-- 自动滚动 Banner -->
  <swiper
    class="swiper"
    autoplay="{{true}}"
    interval="3000"
    duration="500"
    circular="{{true}}"
    indicator-dots="{{true}}"
    indicator-color="rgba(0,0,0,0.2)"
    indicator-active-color="#1a1a1a"
  >
    <swiper-item>
      <image class="banner-img" src="/images/banner-cooking.png" mode="aspectFill"/>
    </swiper-item>
    <swiper-item>
      <image class="banner-img" src="/images/banner-coffee.png" mode="aspectFill"/>
    </swiper-item>
    <swiper-item>
      <image class="banner-img" src="/images/banner-cocktail.png" mode="aspectFill"/>
    </swiper-item>
  </swiper>

  <!-- 功能入口 -->
  <view class="grid-wrap">

    <!-- 第一行：点菜 咖啡 喝酒 -->
    <view class="grid-row">
      <view class="grid-card" bindtap="goToFood">
        <image class="grid-img" src="/images/icon-food.png" mode="aspectFit"/>
        <text class="grid-label">点菜</text>
      </view>
      <view class="grid-card" bindtap="goToCoffee">
        <image class="grid-img" src="/images/icon-coffee.png" mode="aspectFit"/>
        <text class="grid-label">咖啡</text>
      </view>
      <view class="grid-card" bindtap="goToCocktail">
        <image class="grid-img" src="/images/icon-cocktail.png" mode="aspectFit"/>
        <text class="grid-label">喝酒</text>
      </view>
    </view>

    <!-- 第二行：随机推荐 历史订单 想吃什么 -->
    <view class="grid-row">
      <view class="grid-card" bindtap="goToRandom">
        <image class="grid-img" src="/images/icon-random.png" mode="aspectFit"/>
        <text class="grid-label">随机推荐</text>
      </view>
      <view class="grid-card" bindtap="goToHistory">
        <image class="grid-img" src="/images/icon-history.png" mode="aspectFit"/>
        <text class="grid-label">历史订单</text>
      </view>
      <view class="grid-card" bindtap="goToReservation">
        <image class="grid-img" src="/images/icon-wish.png" mode="aspectFit"/>
        <text class="grid-label">想吃什么</text>
      </view>
    </view>

  </view>
</view>
