/* pages/home/home.wxss */

.page {
  background: #f0f0f0;
  min-height: 100vh;
}

/* ── Banner ── */
.swiper {
  width: 100%;
  height: 400rpx;
  display: block;
}

.banner-img {
  width: 100%;
  height: 400rpx;
  display: block;
  background: #fff;
}

/* ── 功能入口网格 ── */
.grid-wrap {
  padding: 24rpx 22rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.grid-row {
  display: flex;
  flex-direction: row;
  gap: 18rpx;
}

.grid-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 10rpx 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  active-opacity: 0.7;
}

.grid-card:active {
  opacity: 0.75;
  transform: scale(0.97);
}

.grid-img {
  width: 150rpx;
  height: 150rpx;
}

.grid-label {
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  text-align: center;
  letter-spacing: 1rpx;
}
