/* pages/home/home.wxss */

.page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
}

.banner-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 12rpx;
}

.banner-emoji {
  font-size: 100rpx;
}

/* 快捷入口 */
.actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  padding: 30rpx 30rpx 0;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.action-icon {
  font-size: 72rpx;
}

.action-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.action-card--random {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
}

.action-card--random .action-text {
  color: #fff;
}


.section {
  margin: 30rpx 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.rec-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rec-card:last-child {
  border-bottom: none;
}

.rec-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #FFF0E8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rec-emoji {
  font-size: 48rpx;
}

.rec-info {
  flex: 1;
  padding: 0 20rpx;
}

.rec-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.rec-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

.rec-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF6B35;
}

.empty-rec {
  text-align: center;
  color: #bbb;
  padding: 40rpx 0;
  font-size: 26rpx;
}
