/* pages/random/random.wxss */

.page {
  background: #f9f9f9;
  min-height: 100vh;
  padding-top: 200rpx;
  padding-bottom: 400rpx;
}

/* 顶部导航栏 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 128rpx;
  background: rgba(249, 249, 249, 0.85);
  backdrop-filter: blur(40rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48rpx;
  padding-top: 72rpx;
  z-index: 100;
}

.header-left,
.header-right {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 6rpx;
  color: #2d3435;
  text-align: center;
}

/* 页面标题 */
.page-header {
  padding: 48rpx 48rpx 32rpx;
}

.page-label {
  font-size: 20rpx;
  letter-spacing: 8rpx;
  color: #757c7d;
  display: block;
  margin-bottom: 16rpx;
}

.page-title {
  font-size: 80rpx;
  line-height: 1.2;
  letter-spacing: -2rpx;
  color: #2d3435;
  display: block;
}

.divider {
  width: 96rpx;
  height: 2rpx;
  background: #5f5e5e;
  margin-top: 32rpx;
  opacity: 0.3;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-spin {
  font-size: 80rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: #acb3b4;
  letter-spacing: 2rpx;
}

/* 空状态提示 */
.empty-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.tip-text {
  font-size: 28rpx;
  color: #757c7d;
  letter-spacing: 8rpx;
}

/* 菜品列表 */
.dish-list {
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.dish-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  transition: all 0.3s;
  will-change: transform, opacity;
}

.dish-card.removing {
  animation: flyToCart 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.dish-card.removing-bounce {
  animation: bounceAway 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
}

.dish-card.removing-explode {
  animation: explode 0.5s ease-out forwards;
}

@keyframes flyToCart {
  0% {
    transform: translate(0, 0) scale(1);
    opacity: 1;
  }
  70% {
    transform: translate(300rpx, -150rpx) scale(0.3);
    opacity: 0.8;
  }
  100% {
    transform: translate(350rpx, -180rpx) scale(0);
    opacity: 0;
  }
}

@keyframes bounceAway {
  0% {
    transform: translate(0, 0) scale(1) rotate(0deg);
    opacity: 1;
  }
  30% {
    transform: translate(100rpx, -80rpx) scale(1.2) rotate(15deg);
  }
  60% {
    transform: translate(250rpx, -120rpx) scale(0.6) rotate(-10deg);
  }
  100% {
    transform: translate(350rpx, -180rpx) scale(0) rotate(360deg);
    opacity: 0;
  }
}

@keyframes explode {
  0% {
    transform: scale(1);
    opacity: 1;
    filter: blur(0);
  }
  50% {
    transform: scale(1.5);
    opacity: 0.8;
    filter: blur(2rpx);
  }
  100% {
    transform: scale(0);
    opacity: 0;
    filter: blur(10rpx);
  }
}

/* 购物车图标 */
.cart-icon {
  position: fixed;
  top: 280rpx;
  right: 48rpx;
  font-size: 80rpx;
  z-index: 200;
  transition: transform 0.3s;
}

.cart-icon.blink {
  animation: blink 0.4s ease-in-out;
}

@keyframes blink {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.3);
  }
}

.dish-card:active {
  background: #f2f4f4;
}

.dish-icon {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #f2f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-emoji {
  font-size: 72rpx;
  opacity: 0.6;
}

.dish-info {
  flex: 1;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-name {
  font-size: 40rpx;
  color: #2d3435;
  line-height: 1.3;
}

.dish-desc {
  font-size: 20rpx;
  color: #757c7d;
  font-style: italic;
  font-weight: 300;
}

.dish-price {
  font-size: 28rpx;
  font-weight: 500;
  color: #5f5e5e;
  flex-shrink: 0;
}

.dish-right {
  flex-shrink: 0;
}

.cart-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.btn-minus,
.btn-plus {
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid #596061;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #596061;
  line-height: 1;
}

.count-text {
  font-size: 28rpx;
  color: #2d3435;
  min-width: 40rpx;
  text-align: center;
}

/* 底部操作区 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 48rpx 80rpx;
  background: #f9f9f9;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
}

.action-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.btn-random {
  position: relative;
  background: transparent;
  border: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.btn-random::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 240rpx;
  height: 240rpx;
  background: rgba(95, 94, 94, 0.05);
  border-radius: 50%;
  filter: blur(80rpx);
}

.btn-random::after {
  border: none;
}

.btn-icon {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: 0 8rpx 80rpx rgba(45, 52, 53, 0.04);
  border: 2rpx solid rgba(172, 179, 180, 0.1);
  transition: all 0.3s;
}

.btn-random:active .btn-icon {
  transform: scale(0.95);
}

.btn-text {
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: #596061;
  font-weight: 500;
}

.footer-note {
  font-size: 20rpx;
  color: #757c7d;
  text-align: center;
  line-height: 1.6;
  letter-spacing: 4rpx;
  max-width: 400rpx;
}
