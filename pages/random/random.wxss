/* pages/random/random.wxss */

.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 240rpx;
}

/* 顶部 */
.header {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spin {
  font-size: 80rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* 菜品列表 */
.dish-list {
  padding: 24rpx 30rpx 0;
}

.dish-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.dish-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  background: #F0EDFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dish-emoji {
  font-size: 52rpx;
}

.dish-info {
  flex: 1;
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.dish-desc {
  font-size: 22rpx;
  color: #999;
}

.dish-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #FF6B35;
  margin-top: 4rpx;
}

/* 数量控制 */
.qty-ctrl {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-add,
.btn-minus {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1;
}

.btn-add {
  background: #FF6B35;
  color: #fff;
}

.btn-minus {
  background: #fff;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

.qty-num {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  min-width: 32rpx;
  text-align: center;
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-again {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  padding: 24rpx 0;
  text-align: center;
}

.btn-again::after {
  border: none;
}

/* 购物车结算栏 */
.cart-bar {
  background: #333;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cart-badge {
  background: #FF6B35;
  color: #fff;
  border-radius: 50%;
  width: 48rpx;
  height: 48rpx;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-total {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.cart-checkout {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
}
