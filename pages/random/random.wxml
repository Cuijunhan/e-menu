<!--pages/random/random.wxml-->
<view class="page">

  <!-- 顶部标题区 -->
  <view class="header">
    <text class="header-title">🎲 今日随机菜单</text>
    <text class="header-sub">命运之轮已为你转动</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spin">🎲</view>
    <text class="loading-text">正在随机...</text>
  </view>

  <!-- 菜品列表 -->
  <view wx:else class="dish-list">
    <view
      wx:for="{{dishes}}"
      wx:key="id"
      class="dish-card"
    >
      <!-- 菜品图标 -->
      <view class="dish-img">
        <text class="dish-emoji">🍽</text>
      </view>

      <!-- 菜品信息 -->
      <view class="dish-info">
        <text class="dish-name">{{item.name}}</text>
        <text class="dish-desc">{{item.description}}</text>
        <text class="dish-price">¥{{item.price}}</text>
      </view>

      <!-- 数量控制 -->
      <view class="qty-ctrl">
        <view
          wx:if="{{item.cartQty > 0}}"
          class="btn-minus"
          bindtap="onRemove"
          data-id="{{item.id}}"
        >－</view>
        <text wx:if="{{item.cartQty > 0}}" class="qty-num">{{item.cartQty}}</text>
        <view
          class="btn-add"
          bindtap="onAdd"
          data-dish="{{item}}"
        >＋</view>
      </view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="footer">
    <button class="btn-again" bindtap="onRandom">🎲 再次随便</button>

    <!-- 购物车栏（有商品时显示） -->
    <view wx:if="{{cartCount > 0}}" class="cart-bar" bindtap="goToCart">
      <view class="cart-left">
        <view class="cart-badge">{{cartCount}}</view>
        <text class="cart-total">¥{{cartTotal}}</text>
      </view>
      <text class="cart-checkout">去结算</text>
    </view>
  </view>

</view>
