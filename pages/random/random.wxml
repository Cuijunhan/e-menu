<!--pages/random/random.wxml-->
<view class="page">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="header-title">The Daily Ritual</text>
    <view class="header-right"></view>
  </view>

  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-label">今日推荐</text>
    <text class="page-title">随机菜单</text>
    <view class="divider"></view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spin">🎲</view>
    <text class="loading-text">正在随机...</text>
  </view>

  <!-- 空状态提示 -->
  <view wx:elif="{{showEmptyTip}}" class="empty-tip">
    <text class="tip-text">{{emptyTipText}}</text>
  </view>

  <!-- 菜品列表 -->
  <view wx:else class="dish-list">
    <view wx:for="{{dishes}}" wx:key="id" class="dish-card {{item.removing ? 'removing' : ''}} {{item['removing-bounce'] ? 'removing-bounce' : ''}} {{item['removing-explode'] ? 'removing-explode' : ''}}">
      <view class="dish-icon">
        <text class="icon-emoji">🍽</text>
      </view>
      <view class="dish-info">
        <text class="dish-name">{{item.name}}</text>
        <text class="dish-desc">{{item.description}}</text>
      </view>
      <view class="cart-control">
        <text class="btn-plus" catchtap="addToCart" data-id="{{item.id}}" data-name="{{item.name}}" data-price="{{item.price}}">+</text>
      </view>
    </view>
  </view>

  <!-- 购物车图标 -->
  <view class="cart-icon {{cartBlink ? 'blink' : ''}}" bindtap="goToCart">
    🧺
  </view>

  <!-- 底部操作区 -->
  <view class="footer">
    <view class="action-wrap">
      <button class="btn-random" bindtap="onRandom">
        <text class="btn-icon">🎲</text>
        <text class="btn-text">再次随机</text>
      </button>
      <text class="footer-note">LET CHANCE DEFINE YOUR NOURISHMENT TODAY.</text>
    </view>
  </view>

</view>
