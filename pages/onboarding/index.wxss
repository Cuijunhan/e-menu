.page {
  min-height: 100vh;
  background: #f9f9f9;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0 80rpx;
}

.logo { font-size: 96rpx; margin-bottom: 24rpx; }

.title {
  font-size: 56rpx;
  font-weight: 300;
  letter-spacing: 12rpx;
  color: #2d3435;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #acb3b4;
  font-style: italic;
  letter-spacing: 4rpx;
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 40rpx rgba(45,52,53,0.06);
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  color: #2d3435;
  margin-bottom: 12rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #acb3b4;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.field {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.field-label {
  font-size: 26rpx;
  color: #757c7d;
  width: 140rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #2d3435;
  text-align: right;
}

.code-input {
  letter-spacing: 8rpx;
  font-weight: 600;
  font-size: 32rpx;
}

.divider { height: 1rpx; background: #f2f4f4; }

.tip {
  font-size: 22rpx;
  color: #acb3b4;
  font-style: italic;
  text-align: center;
  margin: 32rpx 0;
  line-height: 1.6;
}

.btn-primary {
  background: #2d3435;
  color: #f9f9f9;
  text-align: center;
  padding: 36rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  margin-top: 40rpx;
}

.btn-secondary {
  background: #ebeeef;
  color: #596061;
  text-align: center;
  padding: 36rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.btn-back {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: #acb3b4;
  margin-top: 8rpx;
}

.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 80rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #2d3435;
  letter-spacing: 4rpx;
}
