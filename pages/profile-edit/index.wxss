.page {
  min-height: 100vh;
  background: #f9f9f9;
}

.header {
  position: fixed; top: 0; left: 0; right: 0;
  height: 128rpx; padding-top: 72rpx;
  background: rgba(249,249,249,0.92);
  backdrop-filter: blur(20rpx); z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding-left: 32rpx; padding-right: 48rpx;
}

.back { font-size: 64rpx; color: #5f5e5e; line-height: 1; width: 80rpx; }
.header-title { font-size: 30rpx; font-style: italic; letter-spacing: 4rpx; color: #2d3435; }

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 220rpx 0 64rpx;
}

.avatar-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.avatar-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #2d3435;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-letter {
  font-size: 88rpx;
  color: #ffffff;
  font-weight: 300;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 3rpx solid #f9f9f9;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.avatar-edit-icon {
  font-size: 36rpx;
  color: #2d3435;
  line-height: 1;
  font-weight: 300;
}

.avatar-hint {
  font-size: 22rpx;
  color: #acb3b4;
  letter-spacing: 2rpx;
}

/* 表单 */
.form-section {
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-label {
  font-size: 20rpx;
  letter-spacing: 12rpx;
  color: rgba(89,96,97,0.4);
  margin-left: 8rpx;
}

.form-card {
  background: rgba(242,244,244,0.5);
  border-radius: 32rpx;
  overflow: hidden;
}

.field {
  display: flex;
  align-items: center;
  padding: 40rpx 48rpx;
}

.field-label {
  font-size: 28rpx;
  color: #2d3435;
  width: 120rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #2d3435;
  text-align: right;
}

.field-readonly {
  flex: 1;
  font-size: 28rpx;
  color: #acb3b4;
  text-align: right;
}

.field-hint-row {
  padding: 0 48rpx 28rpx;
}

.field-hint {
  font-size: 20rpx;
  color: #acb3b4;
  letter-spacing: 1rpx;
}

/* 保存按钮 */
.save-wrap {
  padding: 64rpx 48rpx 0;
}

.btn-save {
  background: #2d3435;
  color: #f9f9f9;
  text-align: center;
  padding: 40rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  letter-spacing: 6rpx;
}

.btn-save.disabled {
  opacity: 0.5;
}

/* 头像预览弹窗 */
.preview-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.65); z-index: 500;
  display: flex; align-items: center; justify-content: center;
}

.preview-box {
  width: 80%;
  background: #fff;
  border-radius: 40rpx;
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
}

.preview-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 40rpx;
}
.preview-title { font-size: 30rpx; font-weight: 600; color: #2d3435; letter-spacing: 2rpx; }
.preview-close { font-size: 56rpx; color: #acb3b4; line-height: 1; }

.preview-avatar-wrap {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto 48rpx;
}

.preview-avatar-img {
  width: 280rpx;
  height: 280rpx;
  display: block;
}

.preview-actions {
  display: flex;
  gap: 20rpx;
}

.btn-reselect {
  flex: 1;
  background: #ebeeef;
  color: #757c7d;
  text-align: center;
  padding: 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.btn-confirm {
  flex: 1;
  background: #2d3435;
  color: #f9f9f9;
  text-align: center;
  padding: 32rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}
