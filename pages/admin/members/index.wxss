.page {
  min-height: 100vh;
  background: #f9f9f9;
  width: 100%;
  overflow-x: hidden;
}

.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 128rpx;
  padding-top: 72rpx;
  padding-left: 48rpx;
  background: rgba(249,249,249,0.9);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  display: flex;
  align-items: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 8rpx;
  color: #2d3435;
}

.content {
  width: 100%;
  box-sizing: border-box;
  padding: 160rpx 32rpx 0;
}

.section-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #acb3b4;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

/* 邀请码卡片 */
.invite-card {
  background: #2d3435;
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 16rpx;
}

.invite-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.invite-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.invite-code {
  display: block;
  font-size: 64rpx;
  font-weight: 300;
  letter-spacing: 12rpx;
  color: #ffffff;
}

.invite-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.icon-btn {
  background: rgba(255,255,255,0.15);
  border-radius: 10rpx;
  padding: 14rpx 24rpx;
  text-align: center;
}

.icon-btn.ghost {
  background: transparent;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.icon-btn:active { opacity: 0.6; }

.icon-btn-text {
  font-size: 24rpx;
  color: #ffffff;
}

.invite-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  font-style: italic;
}

/* 成员卡片 */
.member-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 24rpx rgba(45,52,53,0.04);
}

.member-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eef0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 32rpx;
  color: #2d3435;
}

.member-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #2d3435;
  margin-bottom: 8rpx;
}

.member-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.role-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.role-badge.admin {
  background: #2d3435;
  color: #ffffff;
}

.role-badge.member {
  background: #eef0f0;
  color: #acb3b4;
}

.member-btns {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  background: #eef0f0;
  font-size: 24rpx;
  color: #2d3435;
}

.action-btn:active { opacity: 0.6; }

.action-btn.danger {
  background: #fdecea;
  color: #e74c3c;
}

.self-tag {
  font-size: 24rpx;
  color: #acb3b4;
  font-style: italic;
}

.empty-tip {
  text-align: center;
  color: #acb3b4;
  font-size: 28rpx;
  padding: 80rpx 0;
  font-style: italic;
}
