.page { min-height: 100vh; background: #f9f9f9; width: 100%; overflow-x: hidden; }

.header {
  position: fixed; top: 0; left: 0; right: 0;
  height: 128rpx; padding-top: 72rpx;
  background: rgba(249,249,249,0.9);
  backdrop-filter: blur(20rpx); z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding-left: 32rpx; padding-right: 48rpx;
}

.back { font-size: 64rpx; color: #5f5e5e; line-height: 1; width: 80rpx; }
.header-title { font-size: 32rpx; font-style: italic; letter-spacing: 4rpx; color: #2d3435; }

.content { width: 100%; box-sizing: border-box; padding: 160rpx 32rpx 0; }

.section-label {
  display: block; font-size: 20rpx; letter-spacing: 6rpx;
  color: #acb3b4; margin-bottom: 16rpx; padding-left: 4rpx;
}

/* 预约卡片 */
.resv-card {
  background: #fff; border-radius: 16rpx; padding: 36rpx;
  margin-bottom: 20rpx; box-shadow: 0 4rpx 24rpx rgba(45,52,53,0.04);
}

.resv-header {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx;
}

.resv-user { display: flex; align-items: center; gap: 16rpx; }

.user-avatar {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #2d3435;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.user-avatar-text { font-size: 24rpx; color: #ffffff; }
.user-name { font-size: 26rpx; color: #5f5e5e; }

.status-tag { font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 40rpx; letter-spacing: 2rpx; }
.status-tag.pending { background: #fef9ec; color: #d4a017; }
.status-tag.done { background: #eaf7f0; color: #27ae60; }

.resv-dish-name { display: block; font-size: 32rpx; font-weight: 600; color: #2d3435; margin-bottom: 12rpx; }
.resv-link { display: block; font-size: 22rpx; color: #4a90e2; margin-bottom: 8rpx; word-break: break-all; }
.resv-note { display: block; font-size: 24rpx; color: #757c7d; font-style: italic; margin-bottom: 24rpx; }

.resv-actions { display: flex; gap: 12rpx; margin-top: 28rpx; }

.btn-action {
  flex: 1; text-align: center; padding: 20rpx;
  border-radius: 12rpx; font-size: 24rpx; letter-spacing: 2rpx;
}
.btn-action.add-menu { background: #2d3435; color: #f9f9f9; }
.btn-action.mark-done { background: #ebeeef; color: #757c7d; }
.btn-action.delete { background: #fdf0ef; color: #c0392b; flex: 0 0 auto; padding: 20rpx 32rpx; }

.empty { text-align: center; color: #acb3b4; padding: 120rpx 0; font-size: 28rpx; font-style: italic; }

/* 加入菜单弹窗 */
.form-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 500;
  display: flex; flex-direction: column; justify-content: flex-end;
}

.form-panel {
  background: #f9f9f9; border-radius: 32rpx 32rpx 0 0;
  max-height: 88vh; display: flex; flex-direction: column;
}

.form-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 40rpx 48rpx 24rpx; flex-shrink: 0;
}
.form-panel-title { font-size: 32rpx; font-weight: 600; color: #2d3435; letter-spacing: 2rpx; }
.form-panel-close { font-size: 56rpx; color: #acb3b4; line-height: 1; }

.form-panel-scroll {
  flex: 1; overflow: hidden;
  padding: 0 32rpx;
  width: 100%; box-sizing: border-box;
}

.form-panel-footer {
  display: flex; gap: 20rpx; padding: 24rpx 32rpx 48rpx; flex-shrink: 0;
}

/* 表单样式 */
.form-card {
  background: #fff; border-radius: 16rpx;
  overflow: hidden; box-shadow: 0 4rpx 24rpx rgba(45,52,53,0.04);
}

.field { display: flex; align-items: center; padding: 32rpx 36rpx; min-height: 100rpx; }
.field-label { font-size: 26rpx; color: #757c7d; width: 120rpx; flex-shrink: 0; letter-spacing: 2rpx; }
.field-input { flex: 1; font-size: 28rpx; color: #2d3435; text-align: right; padding-right: 4rpx; }
.field-value { flex: 1; font-size: 28rpx; color: #2d3435; text-align: right; }
.field-value.placeholder { color: #dde4e5; }
.divider { height: 1rpx; background: #f2f4f4; margin: 0 36rpx; }

.preview-img { width: 100%; height: 300rpx; display: block; object-fit: cover; }

.field-textarea { align-items: flex-start; padding-top: 28rpx; padding-bottom: 28rpx; }
.textarea-input { flex: 1; font-size: 28rpx; color: #2d3435; text-align: right; min-height: 80rpx; line-height: 1.6; padding-right: 4rpx; }

.btn-cancel {
  flex: 1; background: #ebeeef; color: #757c7d;
  text-align: center; padding: 36rpx; border-radius: 16rpx;
  font-size: 28rpx; letter-spacing: 2rpx;
}
.btn-submit {
  flex: 2; background: #2d3435; color: #f9f9f9;
  text-align: center; padding: 36rpx; border-radius: 16rpx;
  font-size: 28rpx; letter-spacing: 2rpx;
}

/* 图片预览弹窗 */
.img-preview-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 600;
  display: flex; align-items: center; justify-content: center;
  padding: 48rpx;
}
.img-preview-panel {
  background: #fff; border-radius: 24rpx;
  overflow: hidden; width: 100%;
}
.img-preview-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 36rpx 24rpx;
}
.img-preview-title { font-size: 28rpx; font-weight: 600; color: #2d3435; }
.img-preview-close { font-size: 52rpx; color: #acb3b4; line-height: 1; }
.img-preview-frame { width: 100%; position: relative; padding-bottom: 100%; overflow: hidden; }
.img-preview-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.img-preview-footer {
  display: flex; gap: 20rpx; padding: 24rpx 32rpx 32rpx;
}

/* 食材区域（表单内） */
.ing-section { padding: 28rpx 36rpx; }
.ing-section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.ing-add-btn { font-size: 22rpx; color: #4a90e2; padding: 8rpx 20rpx; background: #eef3f8; border-radius: 8rpx; }
.ing-tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.ing-tag {
  display: flex; align-items: center; gap: 10rpx;
  background: #ebeeef; border-radius: 8rpx; padding: 10rpx 16rpx;
}
.ing-tag-name { font-size: 24rpx; color: #2d3435; }
.ing-tag-amount { font-size: 22rpx; color: #757c7d; }
.ing-tag-del { font-size: 28rpx; color: #acb3b4; }
.ing-empty { font-size: 22rpx; color: #dde4e5; font-style: italic; }

/* 食材选择器弹窗 */
.ing-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 600;
  display: flex; flex-direction: column; justify-content: flex-end;
}
.ing-panel {
  background: #f9f9f9; border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh; display: flex; flex-direction: column; padding-bottom: 48rpx;
}
.ing-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 40rpx 48rpx 24rpx;
}
.ing-panel-title { font-size: 30rpx; font-weight: 600; color: #2d3435; flex: 1; text-align: center; }
.ing-panel-close { font-size: 52rpx; color: #acb3b4; line-height: 1; }
.ing-back-btn { font-size: 40rpx; color: #acb3b4; line-height: 1; }

.ing-search-wrap { padding: 0 32rpx 16rpx; }
.ing-search {
  width: 100%; box-sizing: border-box;
  background: #fff; border-radius: 12rpx;
  padding: 20rpx 28rpx; font-size: 26rpx; color: #2d3435;
}

.ing-pick-scroll { flex: 1; max-height: 48vh; padding: 0 32rpx; }
.ing-pick-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 24rpx; background: #fff; border-radius: 12rpx; margin-bottom: 8rpx;
}
.ing-pick-name { font-size: 28rpx; color: #2d3435; }
.ing-pick-unit { font-size: 22rpx; color: #acb3b4; }
.ing-pick-empty { text-align: center; color: #acb3b4; padding: 60rpx 0; font-size: 26rpx; font-style: italic; }

.ing-new-row {
  margin: 16rpx 32rpx 0;
  padding: 28rpx; background: #eef3f8; border-radius: 12rpx;
  text-align: center;
}
.ing-new-text { font-size: 26rpx; color: #4a90e2; }

.ing-amount-body { padding: 32rpx 48rpx; }
.ing-amount-label { display: block; font-size: 26rpx; color: #757c7d; margin-bottom: 24rpx; }
.ing-amount-row { display: flex; align-items: center; gap: 20rpx; }
.ing-amount-input {
  flex: 1; background: #fff; border-radius: 12rpx;
  padding: 24rpx 28rpx; font-size: 32rpx; color: #2d3435;
}
.ing-unit-picker {
  background: #fff; border-radius: 12rpx;
  padding: 24rpx 28rpx; font-size: 28rpx; color: #2d3435;
  display: flex; align-items: center; min-width: 120rpx;
}

.ing-new-form-row { display: flex; align-items: center; gap: 20rpx; }
.ing-new-form-label { font-size: 26rpx; color: #757c7d; width: 120rpx; flex-shrink: 0; }
.ing-new-form-input {
  flex: 1; background: #fff; border-radius: 12rpx;
  padding: 24rpx 28rpx; font-size: 28rpx; color: #2d3435;
}

.ing-confirm-btn {
  margin: 16rpx 32rpx 0;
  background: #2d3435; color: #f9f9f9;
  text-align: center; padding: 36rpx; border-radius: 16rpx;
  font-size: 28rpx; letter-spacing: 4rpx;
}
