.page {
  min-height: 100vh;
  background: #f9f9f9;
  width: 100%;
  overflow-x: hidden;
}

.header {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 128rpx;
  padding-top: 72rpx;
  padding-left: 48rpx;
  background: rgba(249,249,249,0.9);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  display: flex;
  align-items: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 8rpx;
  color: #2d3435;
}

.content {
  width: 100%;
  box-sizing: border-box;
  padding: 160rpx 32rpx 0;
}

.section-label {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #acb3b4;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.nav-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 36rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 24rpx rgba(45,52,53,0.04);
}

.nav-card:active { opacity: 0.7; }

.nav-card.danger .nav-title { color: #acb3b4; }

.nav-left {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.nav-icon { font-size: 56rpx; }

.nav-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #2d3435;
  margin-bottom: 6rpx;
}

.nav-desc {
  display: block;
  font-size: 22rpx;
  color: #acb3b4;
  font-style: italic;
}

.nav-arrow {
  font-size: 48rpx;
  color: #dde4e5;
}
