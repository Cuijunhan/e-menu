.page { min-height: 100vh; background: #f9f9f9; width: 100%; overflow-x: hidden; }

.header {
  position: fixed; top: 0; left: 0; right: 0;
  height: 128rpx; padding-top: 72rpx;
  background: rgba(249,249,249,0.9);
  backdrop-filter: blur(20rpx); z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding-left: 32rpx; padding-right: 48rpx;
}

.back { font-size: 64rpx; color: #5f5e5e; line-height: 1; width: 80rpx; }
.header-title { font-size: 32rpx; font-style: italic; letter-spacing: 4rpx; color: #2d3435; }

.content { width: 100%; box-sizing: border-box; padding: 160rpx 32rpx 0; }

.section-label {
  display: block; font-size: 20rpx; letter-spacing: 6rpx;
  color: #acb3b4; margin-bottom: 16rpx; padding-left: 4rpx;
}

.order-card {
  background: #fff; border-radius: 16rpx; padding: 36rpx;
  margin-bottom: 20rpx; box-shadow: 0 4rpx 24rpx rgba(45,52,53,0.04);
}

.order-header {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 28rpx;
}

.order-id-wrap { display: flex; align-items: baseline; gap: 12rpx; }
.order-label { font-size: 20rpx; letter-spacing: 4rpx; color: #acb3b4; }
.order-id { font-size: 28rpx; font-weight: 600; color: #2d3435; letter-spacing: 2rpx; }

.status-tag {
  font-size: 22rpx; padding: 8rpx 20rpx; border-radius: 40rpx; letter-spacing: 2rpx;
}
.status-tag.pending { background: #fef9ec; color: #d4a017; }
.status-tag.done { background: #eaf7f0; color: #27ae60; }

.order-user {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #2d3435;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.user-avatar-text { font-size: 24rpx; color: #ffffff; }

.user-name { font-size: 26rpx; color: #5f5e5e; }

.order-items { margin-bottom: 24rpx; }

.order-item {
  display: flex; align-items: center; padding: 12rpx 0;
  border-bottom: 1rpx solid #f2f4f4;
}

.item-name { flex: 1; font-size: 26rpx; color: #2d3435; }
.item-qty { font-size: 24rpx; color: #acb3b4; margin-right: 24rpx; }
.item-price { font-size: 26rpx; color: #5f5e5e; }

.order-footer {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx;
}

.order-time { font-size: 22rpx; color: #acb3b4; font-style: italic; }
.order-total { font-size: 36rpx; font-weight: 600; color: #2d3435; }

.order-actions { display: flex; gap: 16rpx; }

.btn-action {
  flex: 1; text-align: center; padding: 20rpx;
  border-radius: 12rpx; font-size: 24rpx; letter-spacing: 2rpx;
}
.btn-action.complete { background: #2d3435; color: #f9f9f9; }
.btn-action.revert { background: #ebeeef; color: #757c7d; }
.btn-action.delete { background: #fdf0ef; color: #c0392b; }

.btn-ingredients {
  font-size: 22rpx; color: #acb3b4; letter-spacing: 2rpx;
  text-align: right; padding: 16rpx 0 24rpx; margin-bottom: 4rpx;
}

.empty { text-align: center; color: #acb3b4; padding: 120rpx 0; font-size: 28rpx; font-style: italic; }

/* 食材汇总弹窗 */
.ingr-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 500;
  display: flex; flex-direction: column; justify-content: flex-end;
}

.ingr-panel {
  background: #f9f9f9; border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh; display: flex; flex-direction: column;
}

.ingr-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 40rpx 48rpx 24rpx; flex-shrink: 0;
}
.ingr-title { font-size: 28rpx; font-weight: 600; color: #2d3435; letter-spacing: 2rpx; }
.ingr-close { font-size: 56rpx; color: #acb3b4; line-height: 1; }

.ingr-scroll { flex: 1; overflow: hidden; padding: 0 32rpx; }

.ingr-loading { text-align: center; padding: 80rpx 0; color: #acb3b4; font-size: 26rpx; }

.ingr-dish-block {
  background: #fff; border-radius: 16rpx; padding: 32rpx 36rpx;
  margin-bottom: 20rpx; box-shadow: 0 2rpx 16rpx rgba(45,52,53,0.04);
}

.ingr-dish-header {
  display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24rpx;
}
.ingr-dish-name { font-size: 30rpx; font-weight: 600; color: #2d3435; }
.ingr-dish-qty { font-size: 24rpx; color: #acb3b4; }

.ingr-section { margin-bottom: 20rpx; }
.ingr-section-label {
  display: block; font-size: 18rpx; letter-spacing: 4rpx;
  color: #acb3b4; margin-bottom: 8rpx;
}
.ingr-section-value {
  display: block; font-size: 26rpx; color: #2d3435; line-height: 1.8; white-space: pre-wrap;
}

.ingr-empty-dish { font-size: 24rpx; color: #dde4e5; font-style: italic; }

.ingr-ing-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10rpx 0; border-bottom: 1rpx solid #f2f4f4;
}
.ingr-ing-name { font-size: 26rpx; color: #2d3435; }
.ingr-ing-amount { font-size: 22rpx; color: #acb3b4; }

.ingr-summary-block {
  background: #2d3435; border-radius: 16rpx;
  padding: 32rpx 36rpx; margin-top: 8rpx; margin-bottom: 8rpx;
}
.ingr-summary-title {
  display: block; font-size: 18rpx; letter-spacing: 6rpx;
  color: rgba(255,255,255,0.5); margin-bottom: 20rpx;
}
.ingr-summary-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.ingr-summary-row:last-child { border-bottom: none; }
.ingr-summary-name { font-size: 28rpx; color: #ffffff; }
.ingr-summary-total { font-size: 26rpx; color: rgba(255,255,255,0.7); font-weight: 500; }
