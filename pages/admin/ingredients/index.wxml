<view class="page">
  <view class="header">
    <text class="back" bindtap="goBack">‹</text>
    <text class="header-title">食材数据库</text>
    <view style="width:80rpx;"></view>
  </view>

  <scroll-view class="content" scroll-y>
    <text class="section-label">INGREDIENTS ({{ingredients.length}})</text>

    <view class="ing-list">
      <view class="ing-row" wx:for="{{ingredients}}" wx:key="id">
        <view class="ing-info">
          <text class="ing-name">{{item.name}}</text>
          <text class="ing-unit" wx:if="{{item.unit}}">默认单位：{{item.unit}}</text>
        </view>
        <view class="btn-del" bindtap="deleteIngredient" data-id="{{item.id}}" data-name="{{item.name}}">删除</view>
      </view>
      <view class="empty" wx:if="{{ingredients.length === 0}}"><text>暂无食材，请在下方添加</text></view>
    </view>

    <text class="section-label" style="margin-top:48rpx;">ADD INGREDIENT</text>

    <view class="form-card">
      <view class="field">
        <text class="field-label">食材名称 *</text>
        <input class="field-input" placeholder="如：五花肉" value="{{form.name}}" bindinput="onNameInput" confirm-type="done" />
      </view>
      <view class="divider"></view>
      <view class="field">
        <text class="field-label">默认单位</text>
        <picker mode="selector" range="{{unitOptions}}" value="{{unitIndex}}" bindchange="onUnitChange">
          <text class="field-value">{{unitOptions[unitIndex]}}</text>
        </picker>
      </view>
    </view>

    <view class="btn-row">
      <view class="btn-primary" bindtap="addIngredient">添加食材</view>
    </view>

    <view style="height:120rpx;"></view>
  </scroll-view>
</view>
